{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true
  },
  "enabledManagers": ["pep621", "nix", "github-actions"],
  "packageRules": [
    {
      "description": "Create individual PRs for each Python library",
      "matchManagers": ["pep621"],
      "groupName": null
    },
    {
      "description": "Group root flake.nix inputs together",
      "matchManagers": ["nix"],
      "matchFileNames": ["flake.nix"],
      "groupName": "nix flake inputs (root)"
    },
    {
      "description": "Group dev/flake.nix inputs together",
      "matchManagers": ["nix"],
      "matchFileNames": ["dev/flake.nix"],
      "groupName": "nix flake inputs (dev)"
    },
    {
      "description": "Descriptive PR title for uv.lock maintenance",
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["lockFileMaintenance"],
      "prTitle": "chore(deps): lock file maintenance (uv.lock)"
    },
    {
      "description": "Descriptive PR title for root flake.lock maintenance",
      "matchManagers": ["nix"],
      "matchFileNames": ["flake.nix"],
      "matchUpdateTypes": ["lockFileMaintenance"],
      "prTitle": "chore(deps): lock file maintenance (flake.lock)"
    },
    {
      "description": "Descriptive PR title for dev/flake.lock maintenance",
      "matchManagers": ["nix"],
      "matchFileNames": ["dev/flake.nix"],
      "matchUpdateTypes": ["lockFileMaintenance"],
      "prTitle": "chore(deps): lock file maintenance (dev/flake.lock)"
    }
  ]
}
